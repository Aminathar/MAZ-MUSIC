# MAZ server configuration
# ------------------------
# Copy this file to `.env` and adjust as needed.
# Then start the server with:
#   uvicorn server:app --host 0.0.0.0 --port 3000 --env-file .env

# URL of the ACE-Step API server (must be running before MAZ starts).
ACESTEP_API=http://localhost:8001

# Admin password protecting the /admin/* endpoints.
# CHANGE THIS for any non-local deployment.
ADMIN_PASSWORD=admin1234

# Per-IP daily generation cap.
MAX_PER_DAY=10

# Where ACE-Step writes generated audio files. MAZ scans this directory as
# a fallback when the API doesn't return a file path. Leave blank to use the
# default (~/Desktop/aimusicgenerator/ACE-Step-1.5/.cache/acestep/tmp/api_audio).
ACESTEP_AUDIO_DIR=

# Gemini free API key for high-quality Kazakh lyrics generation.
# Get a free key from https://aistudio.google.com/apikey
# When set, Kazakh lyrics requests use Gemini before falling back to local Ollama.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
